# ============================================================
# tianji-oracle 项目配置
# ============================================================

# ------------------------------------------------------------
# 项目类型：AI必需（命格推演必须使用AI）
# ------------------------------------------------------------

# ------------------------------------------------------------
# 服务端口（避免与其他项目冲突）
# ------------------------------------------------------------
PORT=3001

# ------------------------------------------------------------
# 认证模式优先级
# ------------------------------------------------------------
# AI必需项目推荐: adc,wif,legacy,offline
# 本地开发优先ADC，生产环境优先WIF
AUTH_PRIORITY=adc,wif,legacy,offline

# ------------------------------------------------------------
# GCP 项目配置
# ------------------------------------------------------------
# 如果不设置，使用全局默认: project-e3177fe6-42e6-4e28-9e1
# GCP_PROJECT_ID=your-custom-project-id
# GCP_PROJECT_NUMBER=your-project-number
# GCP_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GCP_WORKLOAD_IDENTITY_POOL_ID=your-pool-id
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=your-provider-id
GCP_LOCATION=global

# ------------------------------------------------------------
# 模型配置（环境自动切换）
# ------------------------------------------------------------
# 本地开发使用的模型（ADC模式）
MODEL_LOCAL=gemini-2.5-pro

# 生产环境使用的模型（WIF/Vercel模式）
MODEL_PRODUCTION=gemini-3.1-flash-lite

# 如果想统一使用一个模型，设置 MODEL 会覆盖上面两个
# MODEL=gemini-2.5-pro

# ------------------------------------------------------------
# 其他配置
# ------------------------------------------------------------
ALLOWED_ORIGINS=*
